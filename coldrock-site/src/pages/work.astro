---
/**
 * Work — selected engagements / case studies (placeholder).
 *
 * TODO[BRAND]: replace placeholder case studies with real (or
 * suitably anonymized) engagements once approved for publication.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import CTAButton from "../components/CTAButton.astro";

// TODO[BRAND]: replace with real, client-approved case studies.
const caseStudies = [
  {
    sector: "[PLACEHOLDER] Sector",
    title: "[PLACEHOLDER] Engagement headline",
    summary:
      "The challenge, what Cold Rock did at the business–government intersection, and the outcome that followed.",
  },
  {
    sector: "[PLACEHOLDER] Sector",
    title: "[PLACEHOLDER] Engagement headline",
    summary:
      "The challenge, what Cold Rock did at the business–government intersection, and the outcome that followed.",
  },
  {
    sector: "[PLACEHOLDER] Sector",
    title: "[PLACEHOLDER] Engagement headline",
    summary:
      "The challenge, what Cold Rock did at the business–government intersection, and the outcome that followed.",
  },
];
---

<BaseLayout
  title="Work — Cold Rock"
  description="Selected engagements from Cold Rock's advisory work at the intersection of business and government."
>
  <Section>
    <div class="max-w-2xl">
      <p class="text-xs font-medium uppercase tracking-[0.3em] text-ink-400">
        Work
      </p>
      <h1
        class="mt-6 text-4xl leading-tight tracking-tight text-ink-900 sm:text-5xl"
      >
        Selected engagements
      </h1>
      <p class="mt-7 text-lg leading-relaxed text-ink-600">
        Much of our work is confidential by nature. The examples below are
        illustrative of the problems we take on and the outcomes we work
        toward.
      </p>
    </div>

    <div
      class="mt-14 grid gap-px overflow-hidden border border-ink-200 bg-ink-200 md:grid-cols-3"
    >
      {
        caseStudies.map((study) => (
          <article class="flex flex-col bg-white p-8">
            {/* TODO[BRAND]: add case study thumbnail/image when available */}
            <div
              class="mb-6 flex h-40 items-center justify-center bg-ink-100 text-xs uppercase tracking-[0.2em] text-ink-400"
              aria-hidden="true"
            >
              [PLACEHOLDER]
            </div>
            <p class="text-xs font-medium uppercase tracking-[0.25em] text-ink-400">
              {study.sector}
            </p>
            <h2 class="mt-3 text-xl text-ink-900">{study.title}</h2>
            <p class="mt-3 text-sm leading-relaxed text-ink-600">
              {study.summary}
            </p>
          </article>
        ))
      }
    </div>

    <div
      class="mt-12 border border-dashed border-ink-300 p-10 text-center"
    >
      <p class="text-ink-600">
        Case studies are being prepared for publication.
      </p>
      <div class="mt-6 flex justify-center">
        <CTAButton href="/contact" variant="secondary">
          Ask about relevant work
        </CTAButton>
      </div>
    </div>
  </Section>
</BaseLayout>
