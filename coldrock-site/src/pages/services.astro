---
/**
 * Services — the firm's advisory offerings.
 *
 * TODO[BRAND]: refine offering names, scope, and "what's included"
 * detail as the catalog firms up.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import CTAButton from "../components/CTAButton.astro";

const services = [
  {
    title: "Government Navigation & Strategy",
    description:
      "Understand exactly where your growth intersects public-sector authority — and build the strategy to engage federal, state, and local government with confidence.",
    includes: [
      "Public-sector landscape & stakeholder mapping",
      "Engagement & positioning strategy",
      "Regulatory and policy navigation",
    ],
  },
  {
    title: "Funding & Resource Access",
    description:
      "Find and pursue the grants, incentives, and programs you qualify for — across economic and workforce development and beyond — and stand up the process to win and manage them.",
    includes: [
      "Grant & incentive opportunity identification",
      "Application strategy & readiness",
      "Program & compliance setup",
    ],
  },
  {
    title: "Systems for Growth & Scale",
    description:
      "Build the operating systems, partnerships, and infrastructure that let small and mid-size organizations grow — and sustain that growth past the next milestone.",
    includes: [
      "Operating model & process design",
      "Partnership & ecosystem development",
      "Capacity & infrastructure planning",
    ],
  },
  {
    title: "Advisory & Problem Solving",
    description:
      "Practical, boutique advisement for the problem in front of you: we understand it deeply, then deliver the solution — strategy, work product, issue development, or execution.",
    includes: [
      "Strategic counsel & decision support",
      "Issue development & work product",
      "Access to a curated network of practitioners",
    ],
  },
];
---

<BaseLayout
  title="Services — Cold Rock"
  description="Cold Rock's advisory offerings — government navigation, funding and resource access, systems for growth, and practical problem solving."
>
  <Section>
    <div class="max-w-2xl">
      <p class="text-xs font-medium uppercase tracking-[0.3em] text-ink-400">
        Services
      </p>
      <h1
        class="mt-6 text-4xl leading-tight tracking-tight text-ink-900 sm:text-5xl"
      >
        Advisory, scoped to the moment
      </h1>
      <p class="mt-7 text-lg leading-relaxed text-ink-600">
        Every engagement starts with the problem, not a template. The
        offerings below are the shapes that work tends to take — most clients
        begin with one and grow into the others as needs evolve.
      </p>
    </div>

    <div
      class="mt-14 grid gap-px overflow-hidden border border-ink-200 bg-ink-200 md:grid-cols-2"
    >
      {
        services.map((service, i) => (
          <div class="bg-white p-8 md:p-10">
            <p class="text-sm text-ink-400">
              {String(i + 1).padStart(2, "0")}
            </p>
            <h2 class="mt-3 text-2xl text-ink-900">{service.title}</h2>
            <p class="mt-4 leading-relaxed text-ink-600">
              {service.description}
            </p>
            <ul class="mt-6 space-y-2">
              {service.includes.map((item) => (
                <li class="flex items-start gap-2 text-sm text-ink-600">
                  <span class="mt-1 text-ink-400" aria-hidden="true">
                    —
                  </span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="mt-12">
      <CTAButton href="/contact">Discuss your needs</CTAButton>
    </div>
  </Section>
</BaseLayout>
